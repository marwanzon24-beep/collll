<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Neon Game Hub</title>

<style>
body{
  margin:0;
  font-family:Arial;
  direction:rtl;
  background: linear-gradient(270deg,#ffeb3b,#2196f3,#ff9800);
  background-size:400% 400%;
  animation:bg 9s ease infinite;
}

@keyframes bg{
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}

.container{
  max-width:420px;
  margin:auto;
  padding:15px;
}

.card{
  background:rgba(255,255,255,0.9);
  padding:15px;
  border-radius:18px;
  margin-top:15px;
  box-shadow:0 10px 25px rgba(0,0,0,0.25);
  backdrop-filter: blur(6px);
}

input{
  width:100%;
  padding:10px;
  margin-top:10px;
  border-radius:12px;
  border:1px solid #ccc;
  outline:none;
}

button{
  width:100%;
  padding:12px;
  margin-top:10px;
  border:none;
  border-radius:12px;
  font-weight:bold;
  cursor:pointer;
  color:#fff;
  background:linear-gradient(135deg,#000,#555);
  transition:0.2s;
}

button:hover{transform:scale(1.05)}
button:active{transform:scale(0.95)}

.userBox{
  background:#f5f5f5;
  padding:10px;
  border-radius:12px;
  margin-top:10px;
}
.badge{
  background:#ffeb3b;
  padding:3px 8px;
  border-radius:8px;
  font-size:12px;
}
</style>
</head>

<body>

<div class="container">

  <!-- LOGIN -->
  <div class="card" id="login">
    <h3>🎮 تسجيل دخول</h3>
    <input id="name" placeholder="الاسم">
    <input id="pass" type="password" placeholder="الباسورد">
    <button onclick="login()">دخول</button>
  </div>

  <!-- PANEL -->
  <div class="card" id="panel" style="display:none">

    <h3 id="welcome"></h3>

    <button onclick="addXP()">+ XP ⚡</button>

    <div id="me"></div>

    <div id="admin" style="display:none">
      <h4>👑 Admin</h4>
      <div id="users"></div>
    </div>

  </div>

</div>

<script>

let users = {
  "Aya": {pass:"6678",xp:0},
  "Habiba": {pass:"3342",xp:0},
  "Yassin": {pass:"2217",xp:0},
  "Marwan": {pass:"2234",xp:0},
  "admin": {pass:"admin",xp:999}
};

let current=null;

function login(){

  let n=document.getElementById("name").value.trim();
  let p=document.getElementById("pass").value;

  let found=null;

  for(let k in users){
    if(k.toLowerCase()===n.toLowerCase()){
      found=k;
      break;
    }
  }

  if(found && users[found].pass===p){

    current=found;

    document.getElementById("login").style.display="none";
    document.getElementById("panel").style.display="block";

    document.getElementById("welcome").innerHTML =
      "أهلاً "+found+" <span class='badge'>LVL "+level(users[found].xp)+"</span>";

    if(found==="admin"){
      document.getElementById("admin").style.display="block";
      render();
    }

    show();

  } else {
    alert("❌ غلط في البيانات");
  }
}

function level(xp){
  return Math.floor(xp/50);
}

function show(){
  let u=users[current];
  document.getElementById("me").innerHTML=`
    <div class="userBox">
      ⭐ XP: ${u.xp}<br>
      🏆 Level: ${level(u.xp)}
    </div>
  `;
}

function addXP(){
  users[current].xp += 10;
  show();
  if(current==="admin") render();
}

function render(){
  let html="";
  for(let k in users){
    html+=`
      <div class="userBox">
        ${k} <br>
        XP: <input value="${users[k].xp}"
        onchange="users['${k}'].xp=parseInt(this.value)">
      </div>
    `;
  }
  document.getElementById("users").innerHTML=html;
}

</script>

</body>
</html>
